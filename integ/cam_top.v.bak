// =============================================================
// cam_top.v  — 摄像头集成 (注意点 ②)
// 包装 lab_ex_5_ov5640_sdram_hdmi/src/ov5640/ov5640_dri.v :
//   完成 SCCB(I2C) 寄存器初始化 + 取像 → 输出用户像素流
// 本模块再把 RGB565 → 8bit 灰度并写入帧缓存 (与 cam_eth_tx 等价)
// =============================================================
`timescale 1ns/1ps
module cam_top #(
    parameter IMG_W = 320,
    parameter IMG_H = 240
)(
    input  wire        clk_50,             // ov5640_dri 主时钟 (i2c 用)
    input  wire        rst_n,
    // 摄像头物理引脚
    input  wire        cam_pclk,
    input  wire        cam_vsync,
    input  wire        cam_href,
    input  wire [7:0]  cam_data,
    output wire        cam_rst_n,
    output wire        cam_pwdn,
    output wire        cam_scl,
    inout  wire        cam_sda,
    output wire        cam_init_done,
    // 帧缓存写口
    output reg         fb_we,
    output reg  [$clog2(IMG_W*IMG_H)-1:0] fb_waddr,
    output reg  [7:0]  fb_wdata,
    output reg         frame_done
);
    // ---------- 实例化原厂 ov5640 驱动 (来自 lab_ex_5) ----------
    wire        cmos_frame_vsync;
    wire        cmos_frame_href;
    wire        cmos_frame_valid;
    wire [15:0] cmos_frame_data;       // RGB565 : R5 G6 B5

    ov5640_dri u_ov5640 (
        .clk              (clk_50),
        .rst_n            (rst_n),
        .cam_pclk         (cam_pclk),
        .cam_vsync        (cam_vsync),
        .cam_href         (cam_href),
        .cam_data         (cam_data),
        .cam_rst_n        (cam_rst_n),
        .cam_pwdn         (cam_pwdn),
        .cam_scl          (cam_scl),
        .cam_sda          (cam_sda),
        // 分辨率参数 (若 OV5640 输出更大分辨率, 由用户在 SDRAM 路径
        // 做缩放; 这里直接申请同 IMG_W*IMG_H 的取景窗)
        .cmos_h_pixel     (13'd320),
        .cmos_v_pixel     (13'd240),
        .total_h_pixel    (13'd400),    // 含消隐
        .total_v_pixel    (13'd260),
        .capture_start    (cam_init_done),
        .cam_init_done    (cam_init_done),
        .cmos_frame_vsync (cmos_frame_vsync),
        .cmos_frame_href  (cmos_frame_href),
        .cmos_frame_valid (cmos_frame_valid),
        .cmos_frame_data  (cmos_frame_data)
    );

    // ---------- RGB565 → 8bit 灰度, 并写入 framebuf ----------
    // 灰度近似 : Y = (R*2 + G*4 + B*1)/7 ≈ (R5<<1 + G6 + B5>>1)
    wire [7:0] r8 = {cmos_frame_data[15:11], 3'b0};
    wire [7:0] g8 = {cmos_frame_data[10:5],  2'b0};
    wire [7:0] b8 = {cmos_frame_data[4:0],   3'b0};
    wire [9:0] ysum = r8 + (g8<<1) + b8;
    wire [7:0] ypix = ysum[9:2];

    reg [9:0] x;
    reg [8:0] y;
    reg       vs_d;
    always @(posedge cam_pclk or negedge rst_n) begin
        if (!rst_n) begin
            fb_we<=0; fb_waddr<=0; fb_wdata<=0;
            x<=0; y<=0; vs_d<=0; frame_done<=0;
        end else begin
            fb_we      <= 1'b0;
            frame_done <= 1'b0;
            vs_d       <= cmos_frame_vsync;
            if (cmos_frame_vsync && !vs_d) begin
                x<=0; y<=0;
            end else if (cmos_frame_valid) begin
                if (x<IMG_W && y<IMG_H) begin
                    fb_we    <= 1'b1;
                    fb_waddr <= y*IMG_W + x;
                    fb_wdata <= ypix;
                end
                if (x==IMG_W-1) begin
                    x<=0;
                    if (y==IMG_H-1) frame_done<=1'b1;
                    else            y<=y+1'b1;
                end else x<=x+1'b1;
            end
        end
    end
endmodule
